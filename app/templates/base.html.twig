<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Mon App{% endblock %}</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  {% block stylesheets %}{% endblock %}
</head>

<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="{{ path('app_home') }}">MonSite</a>
      <div class="ms-auto">
        {% if app.user %}
        <span class="text-white me-3">
          {{ app.user.email }}</span>
        <a href="{{ path('app_logout') }}" class="btn btn-outline-light">Déconnexion</a>
        {% else %}
        <a href="{{ path('app_login') }}" class="btn btn-outline-light">Connexion</a>
        {% endif %}
      </div>
    </div>
  </nav>

  {% block body %}{% endblock %}
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  {% block javascripts %}{% endblock %}
</body>

</html>