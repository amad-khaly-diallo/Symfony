{% extends 'base.html.twig' %}

{% block title %}Accueil - MonSite{% endblock %}

{% block stylesheets %}
<style>
    .hero {
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        color: white;
        padding: 6rem 0;
        clip-path: ellipse(100% 90% at 50% 10%);
    }

    .hero h1 {
        font-size: 3.5rem;
        font-weight: 800;
    }

    .hero p {
        font-size: 1.25rem;
        opacity: 0.9;
    }

    .feature-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        padding: 2rem;
    }

    .feature-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 30px rgba(0,0,0,0.15);
    }

    .feature-icon {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 1rem;
    }
</style>
{% endblock %}

{% block body %}
<div class="hero text-center">
    <div class="container">
        <h1>Bienvenue sur MonSite</h1>
        <p class="mt-3 mb-4">Une plateforme simple, rapide et sécurisée.</p>
        {% if not app.user %}
            <a href="{{ path('app_register') }}" class="btn btn-light btn-lg me-3">
                <i class="fas fa-user-plus me-2"></i>S\'inscrire
            </a>
            <a href="{{ path('app_login') }}" class="btn btn-outline-light btn-lg">
                <i class="fas fa-sign-in-alt me-2"></i>Se connecter
            </a>
        {% else %}
            <h4>Bonjour <strong>{{ app.user.email }}</strong> !</h4>
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_admin') }}" class="btn btn-light btn-lg mt-3">
                    <i class="fas fa-cog me-2"></i>Administration
                </a>
            {% else %}
                <a href="{{ path('app_user') }}" class="btn btn-light btn-lg mt-3">
                    <i class="fas fa-user me-2"></i>Mon espace
                </a>
            {% endif %}
        {% endif %}
    </div>
</div>

<div class="container mt-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="feature-card text-center">
                <div class="feature-icon bg-primary bg-opacity-10 text-primary mx-auto">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <h5>Sécurisé</h5>
                <p class="text-muted">Vos données sont protégées avec les meilleures pratiques de sécurité.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card text-center">
                <div class="feature-icon bg-success bg-opacity-10 text-success mx-auto">
                    <i class="fas fa-bolt"></i>
                </div>
                <h5>Rapide</h5>
                <p class="text-muted">Une expérience fluide et réactive pour tous vos besoins.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card text-center">
                <div class="feature-icon bg-warning bg-opacity-10 text-warning mx-auto">
                    <i class="fas fa-users"></i>
                </div>
                <h5>Multi-rôles</h5>
                <p class="text-muted">Gestion des accès admin et utilisateur intégrée.</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
